    "dompurify": "^3.4.11",
    "epubjs": "^0.3.93",
    "filesize": "^11.0.19",
    "js-base64": "^3.8.0",
    "jwt-decode": "^4.0.0",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.5",
    "marked-katex-extension": "^5.1.10",
